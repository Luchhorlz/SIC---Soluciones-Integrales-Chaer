# Core
APP_ENV=development
APP_URL=http://localhost:3000
API_INTERNAL_URL=http://api:8000
# El desarrollo local sin Docker usa http://127.0.0.1:8001 para evitar conflictos.

# Data
DATABASE_URL=postgresql+asyncpg://sic:sic@postgres:5432/sic
REDIS_URL=redis://redis:6379/0

# Auth (configure in Phase 2)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
INTERNAL_API_JWT_SECRET=
# Usar un secreto aleatorio diferente de AUTH_SECRET y de al menos 32 caracteres.
# Callback local: http://localhost:3000/api/auth/callback/google
# Callback público: https://sic.thecottonclub.com.ar/api/auth/callback/google

# Maps (configure in Phase 3)
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_URL_SIGNING_SECRET=
GOOGLE_MAPS_COUNTRY_RESTRICTION=AR

# Billing (configure in Phase 7)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_SUCCESS_URL=
MERCADOPAGO_FAILURE_URL=

# Object storage
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_PUBLIC=sic-public
S3_BUCKET_PRIVATE=sic-private
S3_PRESIGN_ENDPOINT=http://127.0.0.1:9000
DOCUMENT_DOWNLOAD_TTL_SECONDS=60
DOCUMENT_MAX_BYTES=10485760

# Antivirus for private uploads (Phase 6)
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=15

# Email
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Public hosting (never commit real credentials)
PUBLIC_HOSTNAME=sic.thecottonclub.com.ar
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_CREDENTIALS_PATH=
